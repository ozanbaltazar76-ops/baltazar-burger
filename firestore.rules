rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        request.auth.token.email == "adam.osama60@gmail.com" ||
        request.auth.token.email == "ozanbaltazar76@gmail.com" ||
        request.auth.token.email == "hakan.4444fb@gmail.com"
      );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Guests can read essentials
    match /tables/{tableId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Guests can manage orders for shared carts and real-time tracking
    match /orders/{orderId} {
      allow read, write: if true;
    }

    match /carts/{cartId} {
      allow read, write: if true;
    }

    // Guests can update counters for takeaway logic
    match /daily_stats/{statId} {
      allow read, write: if true;
    }

    // Admin-only collections
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /service_calls/{callId} {
      allow read: if isAdmin();
      allow create: if true; // Guests can call waiter
      allow update, delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read, write: if isAdmin();
    }

    match /admins/{email} {
      allow read, write: if isAdmin();
    }
  }
}
